{
  "$id": "https://review-agent.dev/schema/v1.json",
  "$ref": "#/definitions/ReviewAgentConfig",
  "definitions": {
    "ReviewAgentConfig": {
      "type": "object",
      "properties": {
        "extends": {
          "anyOf": [
            {
              "type": "string",
              "const": "org"
            },
            {
              "type": "null"
            }
          ]
        },
        "language": {
          "type": "string",
          "enum": [
            "en-US",
            "ja-JP",
            "zh-CN",
            "zh-TW",
            "ko-KR",
            "de-DE",
            "fr-FR",
            "es-ES",
            "pt-BR",
            "it-IT",
            "ru-RU",
            "pl-PL",
            "tr-TR"
          ],
          "default": "en-US"
        },
        "profile": {
          "type": "string",
          "enum": ["chill", "assertive"],
          "default": "chill"
        },
        "provider": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "anthropic",
                "openai",
                "azure-openai",
                "google",
                "vertex",
                "bedrock",
                "openai-compatible"
              ]
            },
            "model": {
              "type": "string",
              "minLength": 1
            },
            "fallback_models": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            },
            "base_url": {
              "type": "string",
              "format": "uri"
            },
            "region": {
              "type": "string"
            },
            "azure_deployment": {
              "type": "string"
            },
            "vertex_project_id": {
              "type": "string"
            },
            "anthropic_cache_control": {
              "type": "boolean",
              "default": true
            }
          },
          "required": ["type", "model"],
          "additionalProperties": false
        },
        "reviews": {
          "type": "object",
          "properties": {
            "auto_review": {
              "type": "object",
              "properties": {
                "enabled": {
                  "type": "boolean",
                  "default": true
                },
                "drafts": {
                  "type": "boolean",
                  "default": false
                },
                "base_branches": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": ["main", "master", "develop"]
                },
                "paths": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": []
                },
                "trigger_labels": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": []
                },
                "skip_labels": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "default": []
                }
              },
              "additionalProperties": false,
              "default": {}
            },
            "path_filters": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "default": []
            },
            "path_instructions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "path": {
                    "type": "string",
                    "minLength": 1
                  },
                  "instructions": {
                    "type": "string",
                    "minLength": 1
                  },
                  "auto_fetch": {
                    "type": "object",
                    "properties": {
                      "tests": {
                        "type": "boolean",
                        "default": true
                      },
                      "types": {
                        "type": "boolean",
                        "default": true
                      },
                      "siblings": {
                        "type": "boolean",
                        "default": false
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": ["path", "instructions"],
                "additionalProperties": false
              },
              "default": []
            },
            "max_files": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 50
            },
            "max_diff_lines": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "default": 3000
            },
            "ignore_authors": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": ["dependabot[bot]", "renovate[bot]", "github-actions[bot]"]
            },
            "min_confidence": {
              "type": "string",
              "enum": ["high", "medium", "low"],
              "default": "low"
            },
            "request_changes_on": {
              "type": "string",
              "enum": ["critical", "major", "never"],
              "default": "critical"
            },
            "max_steps": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "cost": {
          "type": "object",
          "properties": {
            "max_usd_per_pr": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 1
            },
            "hard_stop": {
              "type": "boolean",
              "default": true
            },
            "daily_cap_usd": {
              "type": "number",
              "exclusiveMinimum": 0,
              "default": 50
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "privacy": {
          "type": "object",
          "properties": {
            "redact_patterns": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            },
            "deny_paths": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            },
            "allowed_url_prefixes": {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "repo": {
          "type": "object",
          "properties": {
            "submodules": {
              "type": "boolean",
              "default": false
            },
            "lfs": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "skills": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        },
        "incremental": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "coordination": {
          "type": "object",
          "properties": {
            "other_bots": {
              "type": "string",
              "enum": ["ignore", "defer_if_present"],
              "default": "ignore"
            },
            "other_bots_logins": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "default": []
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "server": {
          "type": "object",
          "properties": {
            "workspace_strategy": {
              "type": "string",
              "enum": ["sparse-clone", "contents-api", "none"],
              "default": "none"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "codecommit": {
          "type": "object",
          "properties": {
            "approvalState": {
              "type": "string",
              "enum": ["managed", "off"],
              "default": "off"
            }
          },
          "additionalProperties": false,
          "default": {}
        },
        "ruleset": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "min_severity": {
                "type": "string",
                "enum": ["critical", "major", "minor", "info"],
                "default": "info"
              }
            },
            "additionalProperties": false
          },
          "propertyNames": {
            "enum": ["bug", "security", "performance", "maintainability", "style", "docs", "test"]
          },
          "default": {}
        }
      },
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
