{
  "name": "@review-agent/cli",
  "version": "0.0.0",
  "private": true,
  "description": "review-agent CLI. Local-only review runner + config validator + JSON Schema printer + eval driver.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "review-agent": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "21.0.2",
    "@review-agent/config": "workspace:*",
    "@review-agent/core": "workspace:*",
    "@review-agent/llm": "workspace:*",
    "@review-agent/platform-github": "workspace:*",
    "@review-agent/runner": "workspace:*",
    "commander": "12.1.0",
    "yaml": "2.6.1"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "2.1.5",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
