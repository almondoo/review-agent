{
  "name": "@review-agent/config",
  "version": "0.0.0",
  "private": true,
  "description": ".review-agent.yml schema, loader, and JSON Schema export.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@review-agent/core": "workspace:*",
    "@review-agent/llm": "workspace:*",
    "yaml": "2.6.1",
    "zod": "3.25.76",
    "zod-to-json-schema": "3.23.5"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
