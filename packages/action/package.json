{
  "name": "@review-agent/action",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub Action wrapper. Composes core + platform-github + llm + runner + config.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "action.yml",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "1.11.1",
    "@actions/github": "6.0.0",
    "@review-agent/config": "workspace:*",
    "@review-agent/core": "workspace:*",
    "@review-agent/llm": "workspace:*",
    "@review-agent/platform-github": "workspace:*",
    "@review-agent/runner": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "2.1.9",
    "tsup": "8.5.1",
    "typescript": "5.6.3",
    "vitest": "2.1.9"
  }
}
