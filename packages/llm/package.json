{
  "name": "@review-agent/llm",
  "version": "0.0.0",
  "private": true,
  "description": "Provider-agnostic LLM abstraction + drivers (anthropic, openai, azure-openai, google, vertex, bedrock, openai-compatible) over Vercel AI SDK.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "1.0.0",
    "@ai-sdk/openai": "1.0.0",
    "@review-agent/core": "workspace:*",
    "ai": "4.0.0",
    "js-tiktoken": "1.0.16",
    "zod": "3.25.76"
  },
  "peerDependencies": {
    "@ai-sdk/amazon-bedrock": ">=1.0.0",
    "@ai-sdk/azure": ">=1.0.0",
    "@ai-sdk/google": ">=1.0.0",
    "@ai-sdk/google-vertex": ">=1.0.0",
    "@ai-sdk/openai-compatible": ">=0.0.13"
  },
  "peerDependenciesMeta": {
    "@ai-sdk/amazon-bedrock": {
      "optional": true
    },
    "@ai-sdk/azure": {
      "optional": true
    },
    "@ai-sdk/google": {
      "optional": true
    },
    "@ai-sdk/google-vertex": {
      "optional": true
    },
    "@ai-sdk/openai-compatible": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/amazon-bedrock": "1.0.0",
    "@ai-sdk/azure": "1.0.0",
    "@ai-sdk/google": "1.0.0",
    "@ai-sdk/google-vertex": "1.0.0",
    "@ai-sdk/openai-compatible": "0.0.13",
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "2.1.5",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
