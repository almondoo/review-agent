{
  "name": "@review-agent/platform-codecommit",
  "version": "0.0.0",
  "private": true,
  "description": "AWS CodeCommit VCS adapter. STS-only auth; state lives in Postgres only.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-codecommit": "3.1039.0",
    "@review-agent/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "8.5.1",
    "typescript": "5.6.3",
    "vitest": "3.2.4"
  }
}
