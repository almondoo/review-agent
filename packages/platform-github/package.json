{
  "name": "@review-agent/platform-github",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub VCS adapter via @octokit/rest. Implements VCS interface for review-agent.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.1039.0",
    "@google-cloud/secret-manager": "5.6.0",
    "@octokit/auth-app": "7.1.4",
    "@octokit/plugin-retry": "7.1.2",
    "@octokit/plugin-throttling": "9.4.0",
    "@octokit/rest": "21.0.2",
    "@octokit/types": "12.6.0",
    "@review-agent/config": "workspace:*",
    "@review-agent/core": "workspace:*",
    "@review-agent/db": "workspace:*",
    "drizzle-orm": "0.45.2",
    "simple-git": "3.36.0"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "8.5.1",
    "typescript": "5.6.3",
    "vitest": "3.2.4"
  }
}
