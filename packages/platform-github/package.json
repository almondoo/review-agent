{
  "name": "@review-agent/platform-github",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub VCS adapter via @octokit/rest. Implements VCS interface for review-agent.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "21.0.2",
    "@review-agent/core": "workspace:*",
    "simple-git": "3.27.0"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "@vitest/coverage-v8": "2.1.5",
    "tsup": "8.3.0",
    "typescript": "5.6.3",
    "vitest": "2.1.5"
  }
}
