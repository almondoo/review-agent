# Terraform local state and provider plugins. The .terraform.lock.hcl
# file is intentionally committed to pin provider versions reproducibly.
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
crash.log

# Credential files / vars containing secrets — never commit
*.tfvars
!*.example.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editor
.terraform.tfstate.lock.info
