# Copy to .env and fill in. The .env file is gitignored — never
# commit it.

# ----- core -----------------------------------------------------------------

# Postgres password for the application user. Generate with:
#   openssl rand -base64 32
DB_PASSWORD=

# GitHub App identifiers
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=

# Path on the host filesystem to the GitHub App private key PEM.
# Mounted into the container as a Docker secret (read-only).
GITHUB_APP_PEM_FILE=./secrets/github-app.pem

# LLM provider — Anthropic by default. For Bedrock / Vertex / Azure,
# replace with the appropriate env vars per docs/security/byok.md.
ANTHROPIC_API_KEY=

# ----- optional -------------------------------------------------------------

# Container image override (defaults to ghcr.io/almondoo/review-agent:latest).
# REVIEW_AGENT_VERSION=0.3.0

# Webhook port on the host. Default 8080.
# WEBHOOK_PORT=8080

# Output language. BCP-47.
# REVIEW_AGENT_LANGUAGE=en-US

# OTel — pointed at any OTLP HTTP collector. Empty = disabled.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://cloud.langfuse.com/api/public/otel/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>
# LANGFUSE_LOG_BODIES=0

# ----- telemetry profile (--profile telemetry) -----------------------------

# Required only when bringing up the bundled Langfuse instance.
# Generate each with: openssl rand -base64 32
# LANGFUSE_DB_PASSWORD=
# LANGFUSE_NEXTAUTH_SECRET=
# LANGFUSE_SALT=
# LANGFUSE_ENCRYPTION_KEY=
# LANGFUSE_PUBLIC_URL=http://localhost:3000
# LANGFUSE_PORT=3000
