# Copy to .env and fill in the values. .env is gitignored.

# GitHub PAT (classic) or fine-grained token with `pull-requests: write`.
GITHUB_TOKEN=

# Anthropic BYOK key (default provider).
ANTHROPIC_API_KEY=

# Repository to review, in `owner/repo` form.
GITHUB_REPOSITORY=your-org/your-repo

# Optional: head SHA of the PR (only used for state-comment metadata).
# GITHUB_SHA=

# Optional overrides — defaults match the Action defaults.
# REVIEW_AGENT_LANGUAGE=en-US
# REVIEW_AGENT_CONFIG_PATH=.review-agent.yml
# REVIEW_AGENT_COST_CAP_USD=1.0
