{
  "name": "review-agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' build",
    "test": "pnpm -r --filter './packages/**' test",
    "test:coverage": "pnpm -r --filter './packages/**' test:coverage",
    "typecheck": "pnpm -r --filter './packages/**' typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "dev:up:telemetry": "docker compose -f docker-compose.dev.yml --profile telemetry up -d",
    "dev:down": "docker compose -f docker-compose.dev.yml down",
    "dev:reset": "docker compose -f docker-compose.dev.yml down -v",
    "dev:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "dev:db": "docker compose -f docker-compose.dev.yml exec postgres psql -U review -d review_agent",
    "db:generate": "pnpm --filter @review-agent/db db:generate",
    "db:migrate": "pnpm --filter @review-agent/db db:migrate",
    "db:push": "pnpm --filter @review-agent/db db:push",
    "db:studio": "pnpm --filter @review-agent/db db:studio",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.0.0",
    "@changesets/cli": "2.27.9",
    "@types/node": "24.0.0",
    "tsup": "8.5.1",
    "typescript": "5.6.3",
    "vitest": "3.2.4",
    "@vitest/coverage-v8": "3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "drizzle-orm": ">=0.45.2",
      "@tootallnate/once": ">=3.0.1",
      "tmp": ">=0.2.4",
      "fast-xml-parser": ">=5.7.0",
      "esbuild": ">=0.25.0",
      "mathjs": ">=15.2.0",
      "undici": ">=6.24.0",
      "uuid": ">=14.0.0",
      "jsondiffpatch": ">=0.7.2",
      "vite": ">=7.3.2 <8"
    }
  }
}
